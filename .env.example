# ==============================================================================
# Zenemoo AI - Environment Configuration
# ==============================================================================

# Application Meta
APP_NAME="Zenemoo AI"
ENVIRONMENT="development"
DEBUG=true

# Telegram Bot
BOT_TOKEN="8512332781:AAGhYn0O2iGC9sNABe3BqeqpCJv9NNJYzcQ"

# Backend Server
HOST="0.0.0.0"
PORT=8000
SECRET_KEY="zenemoo-secret-key-change-in-production-super-secure-token"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Configuration
# SQLite for development: sqlite+aiosqlite:///./zenemoo.db
# PostgreSQL ready: postgresql+asyncpg://user:password@localhost:5432/zenemoo
DATABASE_URL="sqlite+aiosqlite:///./zenemoo.db"

# Storage Directories
UPLOAD_DIR="uploads"
OUTPUT_DIR="outputs"
TEMP_DIR="temp"
MAX_UPLOAD_SIZE_MB=25

# Hardware Acceleration
# Options: "auto", "cuda", "cpu"
DEVICE="auto"
NUM_WORKERS=4

# Rate Limiting & Processing
RATE_LIMIT_PER_MINUTE=20
